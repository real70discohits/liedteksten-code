% Note: nameclash \chord for gchords and leadsheets
\RequirePackage{savesym}    % pkg to solve nameclash
\RequirePackage{gchordsz}
\savesymbol{chord}  % Saves \chord from gchords as \origchord, to avoid nameclash
\newcommand{\guitartab}{\origchord}  % use \guitartab for \origchord

% *** support rotation ***
\newcommand{\guitartabrot}[3]{%
    \ifthenelse{\equal{\guitarTabOrientation}{traditional}}{%
        \guitartab{#1}{#2}{#3}
    }{%
        \ifthenelse{\equal{\guitarTabOrientation}{right}}{
            \rotatebox[origin=c]{-90}{\raisebox{-0.25cm}{\guitartab{#1}{#2}{#3}}}
        }{%
            \rotatebox[origin=c]{90}{\raisebox{-0.5cm}{\guitartab{#1}{#2}{#3}}}
        }%
    }%
}


% *** support inline and upline positioning of guitartab ***
% \upchord is a macro within gchords, by Yotam Medini, to place chords above lyrics.

% grpt = Guitar Rotated Positioned Tab
\newcommand{\grpt}[4][up]{%
    \ifthenelse{\boolean{showGuitarTabs}}{%
        \ifthenelse{\equal{#1}{up}}{%
            \upchord{\guitartabrot{#2}{#3}{#4}}  % upline
        }{%
            \guitartabrot{#2}{#3}{#4}  % inline
        }
    }{%
        % Do nothing
    }
}

% grpt = Guitar Rotated Positioned Tab with Barré (altijd op 1e fret). 
% 1e 2 params zijn van/tot snaren van de barré.
\newcommand{\grptb}[6][up]{%
    \ifthenelse{\boolean{showGuitarTabs}}{%
        \ifthenelse{\equal{#1}{up}}{%
            \upchord{\setbarre{1}{#2}{#3}\guitartabrot{#4}{#5}{#6}}  % upline
        }{%
            \setbarre{1}{#2}{#3}\guitartabrot{#4}{#5}{#6}  % inline
        }
    }{%
        % Do nothing
    }
}

% hetzelfde als grptb, maar nu kun je ook de relatieve positie van de barré opgeven.
\newcommand{\grptbb}[7][up]{%
    \ifthenelse{\boolean{showGuitarTabs}}{%
        \ifthenelse{\equal{#1}{up}}{%
            \upchord{\setbarre{#2}{#3}{#4}\guitartabrot{#5}{#6}{#7}}  % upline
        }{%
            \setbarre{#2}{#3}{#4}\guitartabrot{#5}{#6}{#7}  % inline
        }
    }{%
        % Do nothing
    }
}

% ****** Define guitartabs/chords ****** 
%  Note 1: all are 'upline' (above lyrics) by default: 
%    To have a tab inline, add [] to the tab in the songtext.
%    Example: \AsevenMaj[] (note that anythong within the [] would have
%    the same effect: I intended [inline], but for now that is redundant)
% 
%  Note 2: Digits are not allowed in the commandname.
%
% Volgorde akkoorden zoals in 
%    "de ongelooflijke akkoordenvinder voor de gitarist" (RMH, 1996)
% Van C naar B: 
% 6, 7, 8, 9, 11, 11+, 13, maj7, maj9, maj11, 
% 7-5, 7-9, 7-10, 7+5, 7+9, 9+5, 7+5-9, 6*9, dim, +5*, sus4, 7sus4, m,
% m6, m7, m9, m7-5, m7-9*, m+7, m9+7, m+5 m6*9

%   ** --- TELLING FRET POSITIE: gewoon vakjes tellen --- **
%   
% Dit is, met gchords, de definitie van G: {3}{p1,p3,p1,p2,p1,p1}{G}
% De 3 parameters betekenen: 3e vakje, vingerzetting1-6, naam.
% Dus vakje 3, dan vingers op 1e, 3e, 1e, 2e etc. vakje, en het heet 'G'.
% Dus: bij F is het 1, bij E is het 0 maar gebruik 't' voor 'thick bar'.
% p=positie (base=1), x=dempen; o=open; eventueel b=base (bold) note.
% Niet gebruiken: n=no-note, dus impliciete 'o' (open).
%
%   ** Akkoord-command-namen en Akkoord-display-namen **
%   Voorbeeld (fictief): 
%       
%       \newcommand{\CmajThirteen}[1][\defpos]{\grpt[#1]{t}{p3,p3,p2,p2,o,o}{C\#13}}
%   
%   ** CmajThirteen is hier de akkoord-command-name: 
%     - zo'n command MOET UNIEK zijn en cijfers zijn niet toegestaan.
%     - Deze naam moet _beschrijvend_ zijn, zodat je 'm makkelijk kunt vinden (en je niet duplicaten gaat aanmaken)
%    
%   ** C#13 is hier de akkoord-display-name: 
%     - dit hoeft niet uniek te zijn, en hier zijn cijfers wel toegestaan.
%     - deze naam hoeft niet uniek beschrijvend te zijn: het kan best zijn dat je twee C7 akkoorden
%        hebt, maar omdat er een uniek plaatje van de greep bij staat is een niet-unieke naam geen probleem.
%
%
%   ** BARRÉ's maken **
% Je kunt als volgt een echte barré maken, zoals deze voor F: \barre{1}{1}{6}\guitartab[#1]{t}{p1,p1p3,p1p3,p1p2,p1,p1}{F}
% Als je een command wil definiëren, gebruik dan grptb (guitar-rotated-positioned-tab-barré):
%       G6: \newcommand{\Gsix}[1][\defpos]{\grptb[#1]{1}{6}{3}{n,p3,p3,p2,p3,n}{G6}} 
% Uitleg: de eerste param, #1, is de optionele die default 'up' is, dus positionering boven de tekst.
% De 2e en 3e zijn de begin- en eindsnaar van de barré (dus meestal {1}{6}).
% % Daarna komen de standaardparameters voor \chord.
% Als je de barré niet op de eerste fret wilt gebruik dan command grptbb: dan is de 2e param
% die van de barré positie, en schuiven de andere param's eentje op.
%
% Er is ook een lelijke oplossing, voor noodgevallen (?), bv F: {t}{p1,p1p3,p1p3,p1p2,p1,p1}{F}
%
% Some confirmation voor akkoordnamen done at: https://www.oolimo.com/en/guitar-chords/analyze
%
% ------------------------------------------------------------


