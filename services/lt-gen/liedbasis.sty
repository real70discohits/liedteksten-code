            in:\songproperty{toonsoort}
        }{}%
        \ifsongproperty{genre}
		{
            % & 
            % (\songproperty{genre})
        }{}%
        \ifsongproperty{maatsoort}
		{
            & 
            maat=\songproperty{maatsoort}
        }{}%
        &% always display tempo indication 
        t=\songproperty{tempo} 
	\end{tabular}
	\par\endgroup
}
	
